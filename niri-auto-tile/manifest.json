{
  "id": "niri-auto-tile",
  "name": "Auto-Tile",
  "version": "1.2.0",
  "minNoctaliaVersion": "4.4.0",
  "author": "pir0c0pter0",
  "license": "MIT",
  "repository": "https://github.com/noctalia-dev/noctalia-plugins",
  "description": "Automatically redistributes niri column widths evenly when windows open or close",
  "tags": ["Bar", "Utility", "System"],

  "entryPoints": {
    "main": "Main.qml",
    "barWidget": "BarWidget.qml",
    "panel": "Panel.qml",
    "settings": "Settings.qml"
  },

  "dependencies": {
    "plugins": []
  },

  "metadata": {
    "commandPrefix": "auto-tile",
    "defaultSettings": {
      "maxVisible": 4,
      "debounceMs": 300,
      "maxEventsPerSecond": 20,
      "enabled": true,
      "onlyAtMax": true,
      "perWorkspace": false,
      "workspaceMaxVisible": {}
    }
  }
}
